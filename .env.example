# ============================================================================
# TTB Label Verify — environment variables
# ============================================================================
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Extractor selection ---
# Default deploy path: PDF text prepass + Tesseract OCR, with optional OpenAI
# VLM fallback for fields OCR cannot read confidently.
# 'openai' and 'azure-openai' are legacy full-document extractor paths kept for
# comparison/testing.
LABEL_EXTRACTOR=tesseract

# --- OpenAI fallback ---
# Optional when LABEL_EXTRACTOR=tesseract; recommended for better extraction on
# decorative labels and dense Government Warning text.
# Required when LABEL_EXTRACTOR=openai.
OPENAI_API_KEY=sk-...

# --- Optional: OpenAI vision/fallback model ---
# Used by LABEL_EXTRACTOR=openai and by the Tesseract fallback.
# Example: gpt-5.4-mini
OPENAI_VLM_MODEL=

# --- Optional: OpenAI provider throttling ---
# Bulk uploads are processed one PDF at a time by the app, while field-level
# OpenAI reads inside that PDF can still run in parallel for latency.
OPENAI_MAX_CONCURRENT_REQUESTS=4
OPENAI_MAX_RETRIES=4

# --- Optional: OCR worker pool ---
# Defaults to 2 locally and 1 on Vercel. Increase carefully; each worker starts
# its own Tesseract WASM heap and traineddata load.
OCR_POOL_SIZE=

# --- Required when LABEL_EXTRACTOR=azure-openai (stub only — not wired in prototype) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=your-vision-deployment

# --- Optional: legacy OpenAI provenance flag ---
# Only affects LABEL_EXTRACTOR=openai. The default Tesseract pipeline ignores
# this and always emits FieldBbox word rectangles for PDF/OCR-sourced values.
# VLM fallback values are text-only and intentionally have no exact bbox.
EXTRACT_PROVENANCE=false

# --- Optional: Postgres (Neon) for application + review persistence ---
# Leave blank to run the app DB-less (verify route still works; no list/history).
# Get a free Neon connection string at https://console.neon.tech/.
# After setting this, run: npm run db:push
DATABASE_URL=

# --- Optional: Langfuse observability + evals ---
# Leave blank to disable tracing entirely (no-op, demo still works).
# For self-hosted Langfuse (production swap path), set LANGFUSE_HOST to your internal URL.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
