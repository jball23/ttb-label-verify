# ============================================================================
# TTB Label Verify — environment variables
# ============================================================================
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Required: AI provider selection ---
# 'openai' uses the public api.openai.com endpoint (default for the prototype)
# 'azure-openai' uses an Azure OpenAI deployment (production swap path — not implemented in prototype)
LABEL_EXTRACTOR=openai

# --- Required when LABEL_EXTRACTOR=openai ---
OPENAI_API_KEY=sk-...

# --- Required when LABEL_EXTRACTOR=azure-openai (stub only — not wired in prototype) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Required: demo password gate ---
# Whatever string a reviewer enters to access the demo
DEMO_PASSWORD=change-me-before-deploying
# Used to sign the auth cookie. Generate with: openssl rand -base64 32
DEMO_PASSWORD_COOKIE_SECRET=replace-with-32-bytes-base64-secret

# --- Optional: provenance / bounding-box generation ---
# 'false' (default) — feature OFF. Model skips the provenance map and the UI
#                     has no click-to-highlight on either side. Measured 4x
#                     faster end-to-end vs bbox=true.
# 'true'            — feature ON. Model returns a bbox + confidence per
#                     extracted field. Application-side bboxes are then
#                     overridden with deterministic AcroForm widget rects.
#                     Costs ~20s of LLM output time on mini.
EXTRACT_PROVENANCE=false

# --- Optional: Postgres (Neon) for application + review persistence ---
# Leave blank to run the app DB-less (verify route still works; no list/history).
# Get a free Neon connection string at https://console.neon.tech/.
# After setting this, run: npm run db:push
DATABASE_URL=

# --- Optional: Langfuse observability + evals ---
# Leave blank to disable tracing entirely (no-op, demo still works).
# For self-hosted Langfuse (production swap path), set LANGFUSE_HOST to your internal URL.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
